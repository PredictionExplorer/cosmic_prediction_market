# Chain to target: 42161 = Arbitrum One (default), 31337 = local anvil.
NEXT_PUBLIC_CHAIN_ID=42161

# The market series contract (GestureSeriesMarket) to display by default.
# Can be overridden per-visit with ?market=0x… in the URL.
NEXT_PUBLIC_MARKET_ADDRESS=

# Optional: custom RPC endpoint (falls back to the chain's public RPC).
NEXT_PUBLIC_RPC_URL=

# Optional: block the market was deployed at — speeds up event scans a lot.
NEXT_PUBLIC_DEPLOY_BLOCK=

# Optional: WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Without it, only injected browser wallets (MetaMask, Rabby, …) are offered.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: canonical site origin for SEO (metadata, sitemap, JSON-LD, social
# cards). Defaults to the production domain; set on preview deployments so
# they emit self-consistent absolute URLs.
NEXT_PUBLIC_SITE_URL=
